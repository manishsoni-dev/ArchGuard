NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://archguard:CHANGE_ME@postgres:5432/archguard?schema=public
REDIS_URL=redis://redis:6379

GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_ESCAPED_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
GITHUB_CLIENT_ID=CHANGE_ME_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
PUBLIC_WEBHOOK_URL=https://archguard.example.com
DEMO_REPO_URL=
DEMO_DRIFT_PR_URL=
DEMO_FIT_PR_URL=
DEMO_ALLOWED_ORIGIN=*

ANALYZER_PROVIDER=rag
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=fake

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_FALLBACK_TO_MOCK=true
RAG_PROMPT_VERSION=archguard-rag-v1
RAG_MAX_CONTEXT_CHARS=20000
DEBUG_RAG_PROMPTS=false

# Required only when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=

APP_VERSION=0.1.0
GIT_SHA=unknown
