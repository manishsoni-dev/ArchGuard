{
  "name": "archguard",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered GitHub PR architecture fitness bot.",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @archguard/api dev",
    "worker": "pnpm --filter @archguard/api worker",
    "replay:webhook": "pnpm --filter @archguard/api replay:webhook",
    "index:repo": "pnpm --filter @archguard/api index:repo",
    "retrieval:test": "pnpm --filter @archguard/api retrieval:test",
    "fixture:create": "pnpm --filter @archguard/api fixture:create",
    "fixture:seed": "pnpm --filter @archguard/api fixture:seed",
    "fixture:index": "pnpm --filter @archguard/api fixture:index",
    "fixture:retrieval": "pnpm --filter @archguard/api fixture:retrieval",
    "fixture:analyze": "pnpm --filter @archguard/api fixture:analyze",
    "verify:phase3": "pnpm --filter @archguard/api verify:phase3",
    "eval:rag": "pnpm --filter @archguard/api eval:rag",
    "smoke:openai-rag": "pnpm --filter @archguard/api smoke:openai-rag",
    "e2e:check": "pnpm --filter @archguard/api e2e:check",
    "inspect:pr": "pnpm --filter @archguard/api inspect:pr",
    "debug:pr": "pnpm --filter @archguard/api inspect:pr",
    "webhook:events": "pnpm --filter @archguard/api webhook:events",
    "queue:inspect": "pnpm --filter @archguard/api queue:inspect",
    "analysis:runs": "pnpm --filter @archguard/api analysis:runs",
    "setup:github-app": "pnpm --filter @archguard/api setup:github-app",
    "setup:github-app:interactive": "pnpm --filter @archguard/api setup:github-app:interactive",
    "validate:github-app": "pnpm --filter @archguard/api validate:github-app",
    "check:port": "pnpm --filter @archguard/api check:port",
    "kill:port": "pnpm --filter @archguard/api kill:port",
    "doctor": "pnpm --filter @archguard/api doctor",
    "validate:prod-env": "pnpm --filter @archguard/api validate:prod-env",
    "smoke:deployment": "pnpm --filter @archguard/api smoke:deployment",
    "deployment:checklist": "pnpm --filter @archguard/api deployment:checklist",
    "github-app:cutover-plan": "pnpm --filter @archguard/api github-app:cutover-plan",
    "hosted:pr-proof": "pnpm --filter @archguard/api hosted:pr-proof",
    "migration:status": "pnpm --filter @archguard/api migration:status",
    "secrets:check": "pnpm --filter @archguard/api secrets:check",
    "railway:diagnose": "pnpm --filter @archguard/api railway:diagnose",
    "railway:domain-check": "pnpm --filter @archguard/api railway:domain-check",
    "railway:cutover-checklist": "pnpm --filter @archguard/api railway:cutover-checklist",
    "production:command-check": "pnpm --filter @archguard/api production:command-check",
    "docker:build:api": "docker build -f Dockerfile.api -t archguard-api:local .",
    "docker:build:worker": "docker build -f Dockerfile.worker -t archguard-worker:local .",
    "verify:local": "node scripts/verify-local.mjs",
    "demo:replit": "node scripts/replit-demo-runner.mjs",
    "build": "pnpm -r build",
    "test": "pnpm --filter @archguard/api test",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.3",
    "typescript": "^5.8.3"
  }
}
